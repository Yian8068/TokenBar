---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).cat
const base = import.meta.env.BASE_URL
---

<section class="catband">
  <div class="container cat-inner">
    <div class="cat-art reveal">
      <div class="menubar" aria-hidden="true">
        <span class="mb-apple">
          <svg viewBox="0 0 384 512" role="img" aria-label="Apple menu">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
          </svg>
        </span>
        <span class="mb-menus"><b>TokenBar</b><span>File</span><span>View</span></span>
        <span class="mb-spacer"></span>
        <img src={`${base}screenshots/menubar.gif`} alt={c.gifAlt} width="240" />
      </div>
      <!-- the other two critters that ship in the tray, animated from the
           app's actual frame sets (hover feeds them tokens) -->
      <div class="critters" aria-hidden="true">
        <span class="critter-pill">
          <span class="sprite cat"></span>
          <span class="mono">oiiai cat</span>
        </span>
        <span class="critter-pill">
          <span class="sprite parrot"></span>
          <span class="mono">party parrot</span>
        </span>
      </div>
      <p class="critters-note mono">{c.crittersNote}</p>
    </div>
    <div class="cat-copy reveal" style="--rd:.1s">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2 set:html={c.h2} />
      <p>{c.body}</p>
      <p class="credit" set:html={c.credit} />
    </div>
  </div>
</section>

<style>
  .catband { padding: clamp(64px, 9vw, 120px) 0; position: relative; }
  .cat-inner {
    display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }
  .cat-art { display: grid; place-items: center; gap: 16px; }

  .critters { display: flex; gap: 12px; }
  .critter-pill {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 8px 16px; border-radius: 999px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--ink) 6%, transparent);
    font-size: 12px; letter-spacing: .06em; color: var(--muted);
    transition: border-color .18s, color .18s;
  }
  .critter-pill:hover { border-color: var(--accent); color: var(--ink-dim); }
  .sprite { display: inline-block; background-repeat: no-repeat; }
  .sprite.cat {
    width: 24px; height: 24px;
    background-image: url('/critters/cat.png');
    background-size: 120px 24px;
    animation: spriteCat 0.8s steps(5) infinite;
  }
  .sprite.parrot {
    width: 24px; height: 18px;
    background-image: url('/critters/parrot.png');
    background-size: 240px 18px;
    animation: spriteParrot 1s steps(10) infinite;
  }
  @keyframes spriteCat { to { background-position-x: -120px; } }
  @keyframes spriteParrot { to { background-position-x: -240px; } }
  /* feeding tokens makes everything spin faster */
  .critter-pill:hover .sprite.cat { animation-duration: 0.25s; }
  .critter-pill:hover .sprite.parrot { animation-duration: 0.32s; }
  @media (prefers-color-scheme: light) {
    .sprite.cat { background-image: url('/critters/cat-light.png'); }
    .sprite.parrot { background-image: url('/critters/parrot-light.png'); }
  }
  .critters-note { font-size: 11.5px; letter-spacing: .05em; color: var(--faint); }
  .menubar {
    width: 100%; max-width: 440px;
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px; border-radius: 14px;
    background: var(--glass-scrim);
    -webkit-backdrop-filter: blur(22px) saturate(1.4);
    backdrop-filter: blur(22px) saturate(1.4);
    border: 1px solid var(--glass-edge);
    box-shadow: inset 0 1px 0 var(--glass-sheen), var(--glass-shadow);
  }
  .mb-apple { display: inline-flex; align-items: center; }
  .mb-apple svg { width: 15px; height: 17px; fill: var(--ink); }
  .mb-menus { display: inline-flex; align-items: center; gap: 16px; font-size: 13px; color: var(--muted); }
  .mb-menus b { color: var(--ink); font-weight: 700; }
  .mb-spacer { flex: 1; }
  @media (max-width: 520px) { .mb-menus span { display: none; } }
  .menubar img { height: 34px; width: auto; border-radius: 6px; }

  .cat-copy h2 { font-size: clamp(28px, 4.4vw, 46px); margin: 14px 0 16px; }
  .cat-copy p { color: var(--muted); max-width: 46ch; }
  .credit {
    margin-top: 20px; font-size: 14px; color: var(--faint);
    border-left: 2px solid var(--accent); padding-left: 14px;
  }
  .credit a { color: var(--accent-bright); border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, transparent); }
  .credit strong { color: var(--ink-dim); }

  @media (max-width: 820px) {
    .cat-inner { grid-template-columns: 1fr; gap: 36px; }
    .cat-art { order: -1; }
  }
</style>
