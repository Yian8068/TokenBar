---
// The signature hero visual: a contribution heatmap rebuilt from scratch in
// CSS (not a screenshot), tinted with the real provider palette. Deterministic
// pseudo-random fill so the build is stable; density rises toward the right
// (recent) like a real usage graph. Cells glow in with a staggered reveal.
const COLS = 53
const ROWS = 7
const PROVIDERS = [
  '--p-anthropic', '--p-openai', '--p-google', '--p-cursor',
  '--p-deepseek', '--p-meta', '--p-mistral',
]

let seed = 20260607
const rand = () => {
  seed = (seed * 1103515245 + 12345) & 0x7fffffff
  return seed / 0x7fffffff
}

type Cell = { provider: string; intensity: number; delay: number; glow: boolean }
const cells: Cell[] = []
for (let c = 0; c < COLS; c++) {
  for (let r = 0; r < ROWS; r++) {
    const recency = c / COLS
    const roll = rand()
    const active = roll < 0.28 + recency * 0.46
    const provider = PROVIDERS[Math.floor(rand() * PROVIDERS.length)]
    const intensity = active ? 0.32 + rand() * 0.68 : 0
    cells.push({ provider, intensity, delay: c * ROWS + r, glow: intensity > 0.78 })
  }
}
---

<div class="heatmap" aria-hidden="true">
  <div class="grid">
    {cells.map((cell) => (
      <span
        class:list={['cell', { glow: cell.glow }]}
        style={`--c: var(${cell.provider}); --a: ${cell.intensity.toFixed(2)}; animation-delay: ${cell.delay * 5}ms;`}
      />
    ))}
  </div>
</div>

<style>
  .heatmap {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    overflow: hidden;
    /* ambience now, not the lead: bias toward the popover side and fade
       hard around the copy so the glass panel stays the protagonist */
    -webkit-mask-image: radial-gradient(120% 110% at 66% 30%, #000 26%, transparent 76%);
    mask-image: radial-gradient(120% 110% at 66% 30%, #000 26%, transparent 76%);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(53, 1fr);
    grid-auto-rows: 1fr;
    gap: 6px;
    width: 1240px;
    max-width: none;
    transform: translateY(-4%) rotate(-0.0001deg);
    opacity: 0.5;
  }
  .cell {
    aspect-ratio: 1;
    border-radius: 3px;
    /* empty cells read as a faint scaffold; active cells fill with provider hue */
    background:
      color-mix(in oklab, var(--c) calc(var(--a) * 100%), color-mix(in oklab, var(--ink) 7%, transparent));
    opacity: 0;
    transform: scale(0.6);
    animation: cellIn 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }
  .cell.glow {
    box-shadow: 0 0 10px -1px color-mix(in oklab, var(--c) 70%, transparent);
  }
  @keyframes cellIn {
    to { opacity: 1; transform: none; }
  }
  @media (max-width: 720px) {
    .grid { width: 1000px; gap: 5px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cell { opacity: 1; transform: none; animation: none; }
  }
</style>
